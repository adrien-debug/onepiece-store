# Backend API (Express) — used by `/api/auth/login` and shop rewrites fallback
CLAWD_BACKEND_URL=http://127.0.0.1:3848

# Same backend for `src/lib/api-client.ts` (cart/checkout API routes)
HEARST_BACKEND_URL=http://127.0.0.1:3848

# Optional: server-side proxy when no NextAuth session (production shop)
# HEARST_API_KEY=
# HEARST_SHOP_USER_ID=
# HEARST_SHOP_USER_EMAIL=
# HEARST_SHOP_TENANT_ID=

# Hearst Next.js app — `POST /api/auth/register` is proxied here (must expose `/api/auth/register`)
HEARST_APP_URL=http://127.0.0.1:3000

# HS256 secret for shop JWT (min 16 chars) — issued by `/api/auth/login` and `/api/auth/register`
ONEPEACE_JWT_SECRET=change-me-min-16-chars

# Supabase (service role) — BFF `/api/customers/*` (tables `clawd_crm_customers`, `clawd_crm_orders`, `clawd_crm_addresses`)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin UI (`/admin/*`) — NextAuth + middleware `ADMIN_EMAILS`
NEXTAUTH_URL=http://127.0.0.1:3100
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
ADMIN_EMAILS=you@example.com
# Optional: same list for client checks
# NEXT_PUBLIC_ADMIN_EMAILS=

# Google OAuth (optional — sinon connexion par mot de passe)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Mot de passe partagé pour provider Credentials (admin uniquement, emails dans ADMIN_EMAILS)
# ONEPEACE_SHOP_PASSWORD=

# Tenant pour `x-tenant-id` (commandes / analytics) — aligné avec le backend
# HEARST_TENANT_ID=
